# Database
DATABASE_URL=postgresql+asyncpg://selectiva:selectiva_dev@postgres:5432/ask_selectiva

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# Long ingest jobs (big PDFs + embeddings): raise if you still see CommitFailedError / rebalance (ms).
# KAFKA_MAX_POLL_INTERVAL_MS=3600000

# Ollama (runs on host - use host.docker.internal for Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
# Same as OLLAMA_MODEL unless you pull a larger model (e.g. mixtral) for long/complex questions
OLLAMA_ESCALATION_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=1024
# httpx read timeout (seconds) for Ollama; first load + big RAG prompts can take several minutes
# OLLAMA_REQUEST_TIMEOUT_SECONDS=900

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Webhook (optional - leave empty to skip HMAC validation)
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO

# --- Google Drive push (optional) ---
# Share the folder with the service account email as Viewer.
# GOOGLE_DRIVE_FOLDER_ID=<from Drive folder URL>
# GOOGLE_DRIVE_TENANT_ID=00000000-0000-0000-0000-000000000001
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# Or: GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# Public HTTPS URL where this API is reachable (for webhooks):
# GOOGLE_DRIVE_PUBLIC_BASE_URL=https://your-domain.com
# Random secret, must appear as ?token= on the registered webhook URL:
# GOOGLE_DRIVE_WEBHOOK_TOKEN=your-long-random-string
